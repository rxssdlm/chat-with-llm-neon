# ======================================
# EJEMPLO DE CONFIGURACIÓN DE ENTORNO
# ======================================
# Copia este archivo como .env y configura tus propios valores

# Base de Datos PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database
DATABASE_URL_ALEMBIC=postgresql://user:password@host:port/database

# Redis (para Celery)
REDIS_PASSWORD=your_redis_password_here
REDIS_HOST=localhost
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://:your_redis_password_here@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:your_redis_password_here@localhost:6379/1

# API Keys y Secretos
GROQ_API_KEY=your_groq_api_key_here
SECRET_KEY=your_secret_key_here

# Configuración de Email (opcional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password

# Otros
DEBUG=False
ENVIRONMENT=development
